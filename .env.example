# 复制本文件为 .env 后再填入真实值
# JWT 签名密钥 - 必须修改为随机字符串 (建议 64 字符以上)
JWT_SECRET=please-change-me-to-a-very-long-random-string-at-least-32-chars

# 宋金钊账号
USER_A_NAME=宋金钊
USER_A_USERNAME=jinzhao
USER_A_PASSWORD=changeme-jinzhao

# 彭沁园账号
USER_B_NAME=彭沁园
USER_B_USERNAME=qinyuan
USER_B_PASSWORD=changeme-qinyuan

# 数据库路径与上传目录 (Docker 内固定为 /data/...)
DATABASE_URL=file:./data/app.db
UPLOAD_DIR=./data/uploads
